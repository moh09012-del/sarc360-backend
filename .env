# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# App
APP_NAME="SARC360 ERP"
ENVIRONMENT=development
DEBUG=true

# Database (Supabase PostgreSQL)
# Format: postgresql+asyncpg://postgres:[PASSWORD]@[HOST]:5432/postgres
# Get from: Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql+asyncpg://postgres:c%23m9gjBZsH6TMMS@db.qpfbyqiazmdtyufyfdos.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — CHANGE THIS in production:  openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-me

# ZATCA Phase 2
ZATCA_ENV=sandbox
ZATCA_CSID=
ZATCA_PRIVATE_KEY_PEM=

# WPS / Mudad
MUDAD_API_KEY=

# WhatsApp notifications
WHATSAPP_API_KEY=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# CORS (comma-separated origins for production)
# "null" allows file:// access in dev; 127.0.0.1:5500 = VSCode Live Server
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5500","http://localhost:5500","null"]
