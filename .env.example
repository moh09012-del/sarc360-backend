# ── SARC360 ERP — Environment Variables ──────────────────────────────────────
# cp .env.example .env   then fill in real values.
# Never commit .env to version control.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="SARC360 ERP"
APP_VERSION="1.0.0"
ENVIRONMENT=development         # development | staging | production
DEBUG=false

# ── Database (Supabase / PostgreSQL via asyncpg) ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security / JWT ────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Saudi Business Constants ──────────────────────────────────────────────────
KSA_VAT_RATE=0.15               # 15% VAT (ZATCA Phase 2)
GOSI_EMPLOYER_RATE=0.10         # 10% employer GOSI
GOSI_EMPLOYEE_RATE=0.09         # 9% employee GOSI (Saudi nationals)
DEFAULT_CURRENCY=SAR
DEFAULT_TIMEZONE=Asia/Riyadh

# ── ZATCA Phase 2 ─────────────────────────────────────────────────────────────
ZATCA_ENV=sandbox               # sandbox | production
ZATCA_CSID=
ZATCA_PRIVATE_KEY_PEM=
ZATCA_API_BASE_URL=https://gw-apic-gov.gazt.gov.sa/e-invoicing/core

# ── WPS / Mudad (Payroll) ──────────────────────────────────────────────────────
MUDAD_API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
WHATSAPP_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Windows terminal fix for Arabic/Unicode in logs ──────────────────────────
# PYTHONIOENCODING=utf-8
